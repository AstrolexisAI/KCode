---
import Base from "../layouts/Base.astro";

const benchmarkResults = [
  {
    model: "qwen-2.5-coder-32b",
    label: "Qwen 2.5 Coder 32B",
    type: "local",
    quantization: "Q4_K_M",
    gpu: "RTX 4090",
    tasks: 12,
    passed: 12,
    passRate: "100%",
    avgTimeMs: 3369,
    avgFirstTokenMs: 344,
    avgTokens: 523,
    note: "Example data",
  },
  {
    model: "ci-mock",
    label: "CI Mock Server",
    type: "mock",
    quantization: "N/A",
    gpu: "N/A",
    tasks: 10,
    passed: 8,
    passRate: "80%",
    avgTimeMs: 1250,
    avgFirstTokenMs: 43,
    avgTokens: 493,
    note: "CI validation baseline",
  },
];

const certificationResults = [
  {
    model: "ci-mock",
    label: "CI Mock Server",
    level: "Bronze",
    score: "28/50",
    tool_calling: "7/10",
    code_generation: "5/10",
    instruction_following: "6/10",
    context_handling: "5/10",
    safety: "5/10",
    note: "CI validation baseline",
  },
];

const badgeColors: Record<string, string> = {
  Gold: "#ffd700",
  Silver: "#c0c0c0",
  Bronze: "#cd7f32",
  Failed: "#666",
};
---

<Base title="Benchmarks — KCode">
  <section class="container bench-page">
    <h1>KCode Model Benchmarks</h1>
    <p class="subtitle">
      Automated performance and compatibility benchmarks for local and cloud models
      running inside KCode. Results are generated by the
      <code>benchmarks/</code> suite against live or mock endpoints.
    </p>

    <!-- Methodology -->
    <h2>Methodology</h2>
    <div class="methodology">
      <div class="method-card">
        <h3>Performance Suite</h3>
        <p>
          12 coding tasks covering type fixes, error handling, unit tests, refactoring,
          bug detection, SQL generation, REST endpoints, and optimization.
          Each task is sent as a chat completion request; the response is validated
          against expected keywords (at least 50% match required to pass).
          Metrics captured: wall-clock time, time-to-first-token, and approximate token count.
        </p>
      </div>
      <div class="method-card">
        <h3>Certification Suite</h3>
        <p>
          50 tasks across 5 categories (10 points each, 50 max).
          Evaluates tool calling accuracy, code generation quality, instruction following,
          context handling over long inputs, and safety alignment.
          Levels: <strong>Gold</strong> (45+), <strong>Silver</strong> (35+),
          <strong>Bronze</strong> (25+), <strong>Failed</strong> (&lt;25).
        </p>
      </div>
      <div class="method-card">
        <h3>Running Benchmarks</h3>
        <pre><code># Performance benchmark
bun run benchmarks/run.ts \
  --model qwen-2.5-coder-32b \
  --api-base http://localhost:10091

# Certification
bun run benchmarks/certification/run.ts \
  --name qwen-2.5-coder-32b \
  --model http://localhost:10091</code></pre>
      </div>
    </div>

    <!-- Performance Comparison -->
    <h2>Performance Comparison</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Model</th>
            <th>Type</th>
            <th>Quant</th>
            <th>GPU</th>
            <th>Tasks</th>
            <th>Passed</th>
            <th>Rate</th>
            <th>Avg Time</th>
            <th>TTFT</th>
            <th>Avg Tokens</th>
          </tr>
        </thead>
        <tbody>
          {benchmarkResults.map((r) => (
            <tr class={r.type === "mock" ? "row-mock" : ""}>
              <td>
                <strong>{r.label}</strong>
                {r.note && <span class="badge">{r.note}</span>}
              </td>
              <td>{r.type}</td>
              <td><code>{r.quantization}</code></td>
              <td>{r.gpu}</td>
              <td>{r.tasks}</td>
              <td>{r.passed}</td>
              <td class={r.passed === r.tasks ? "cell-pass" : "cell-partial"}>{r.passRate}</td>
              <td>{r.avgTimeMs}ms</td>
              <td>{r.avgFirstTokenMs}ms</td>
              <td>{r.avgTokens}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Task Categories Breakdown (Qwen example) -->
    <h2>Task Categories (Qwen 2.5 Coder 32B)</h2>
    <div class="categories">
      <div class="cat-card">
        <h4>Coding</h4>
        <span class="cat-score pass">10/10 passed</span>
        <p>Type fixes, error handling, tests, refactoring, bug finding, SQL, REST, promises, optimization</p>
      </div>
      <div class="cat-card">
        <h4>Context</h4>
        <span class="cat-score pass">2/2 passed</span>
        <p>Function explanation and config priority chain reasoning</p>
      </div>
    </div>

    <!-- Certification Results -->
    <h2>Certification Results</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Model</th>
            <th>Level</th>
            <th>Score</th>
            <th>Tool Calling</th>
            <th>Code Gen</th>
            <th>Instructions</th>
            <th>Context</th>
            <th>Safety</th>
          </tr>
        </thead>
        <tbody>
          {certificationResults.map((r) => (
            <tr>
              <td>
                <strong>{r.label}</strong>
                {r.note && <span class="badge">{r.note}</span>}
              </td>
              <td>
                <span class="cert-badge" style={`background:${badgeColors[r.level]};color:#000`}>
                  {r.level}
                </span>
              </td>
              <td><strong>{r.score}</strong></td>
              <td>{r.tool_calling}</td>
              <td>{r.code_generation}</td>
              <td>{r.instruction_following}</td>
              <td>{r.context_handling}</td>
              <td>{r.safety}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Certification Badges -->
    <h2>Certification Levels</h2>
    <div class="levels">
      <div class="level-card">
        <span class="cert-badge" style={`background:${badgeColors.Gold};color:#000`}>Gold</span>
        <p>45+ / 50 -- Production-ready. Excellent tool calling, code generation, and safety.</p>
      </div>
      <div class="level-card">
        <span class="cert-badge" style={`background:${badgeColors.Silver};color:#000`}>Silver</span>
        <p>35+ / 50 -- Strong model. Reliable for most coding tasks with minor gaps.</p>
      </div>
      <div class="level-card">
        <span class="cert-badge" style={`background:${badgeColors.Bronze};color:#000`}>Bronze</span>
        <p>25+ / 50 -- Functional. Handles basic tasks; may struggle with complex tool use.</p>
      </div>
      <div class="level-card">
        <span class="cert-badge" style="background:#666;color:#fff">Failed</span>
        <p>&lt;25 / 50 -- Below minimum. Not recommended for KCode workflows.</p>
      </div>
    </div>

    <!-- Submit results -->
    <h2>Submit Your Results</h2>
    <p>
      Run the benchmark suite on your hardware and share results.
      JSON output is saved automatically to <code>benchmarks/results/</code>.
      Open a pull request to add your model to this page.
    </p>
    <pre><code># Run both suites and commit results
bun run benchmarks/run.ts --model your-model --api-base http://localhost:10091
bun run benchmarks/certification/run.ts --name your-model --model http://localhost:10091
git add benchmarks/results/
git commit -m "Add benchmark results for your-model"</code></pre>

    <nav class="doc-nav">
      <a href="/docs">&larr; Documentation</a>
      <a href="/download">Download KCode &rarr;</a>
    </nav>
  </section>

  <style>
    .bench-page { padding: 2rem 0 4rem; max-width: 1000px; }
    .subtitle { color: #aaa; margin-bottom: 2rem; line-height: 1.6; }
    h1 { margin-bottom: 0.5rem; }
    h2 { margin-top: 2.5rem; margin-bottom: 1rem; color: #e0e0e0; }

    /* Methodology */
    .methodology { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; }
    .method-card {
      background: #0d1117;
      border: 1px solid #333;
      border-radius: 8px;
      padding: 1.25rem;
    }
    .method-card h3 { margin: 0 0 0.5rem; color: #7c8cf8; font-size: 1rem; }
    .method-card p { color: #aaa; font-size: 0.9rem; line-height: 1.5; margin: 0; }
    .method-card pre {
      background: #161b22;
      border: 1px solid #333;
      border-radius: 6px;
      padding: 0.75rem;
      overflow-x: auto;
      margin: 0;
    }
    .method-card code { color: #c9d1d9; font-size: 0.82rem; }

    /* Tables */
    .table-wrap { overflow-x: auto; margin: 1rem 0; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th, td { text-align: left; padding: 0.6rem 0.75rem; border-bottom: 1px solid #333; white-space: nowrap; }
    th { color: #888; font-weight: 600; background: #0d1117; position: sticky; top: 0; }
    td code { background: #161b22; padding: 2px 6px; border-radius: 4px; font-size: 0.82rem; }
    .row-mock td { opacity: 0.7; }
    .cell-pass { color: #3fb950; font-weight: 600; }
    .cell-partial { color: #d29922; font-weight: 600; }
    .badge {
      display: inline-block;
      font-size: 0.7rem;
      padding: 2px 6px;
      border-radius: 4px;
      background: #333;
      color: #aaa;
      margin-left: 0.5rem;
      vertical-align: middle;
    }

    /* Certification badge */
    .cert-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 4px;
      font-weight: 700;
      font-size: 0.85rem;
    }

    /* Categories */
    .categories { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
    .cat-card {
      background: #0d1117;
      border: 1px solid #333;
      border-radius: 8px;
      padding: 1rem;
    }
    .cat-card h4 { margin: 0 0 0.4rem; color: #e0e0e0; }
    .cat-card p { color: #888; font-size: 0.85rem; margin: 0.4rem 0 0; line-height: 1.4; }
    .cat-score { font-size: 0.85rem; font-weight: 600; }
    .cat-score.pass { color: #3fb950; }

    /* Levels */
    .levels { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
    .level-card {
      background: #0d1117;
      border: 1px solid #333;
      border-radius: 8px;
      padding: 1rem;
    }
    .level-card p { color: #aaa; font-size: 0.85rem; margin: 0.5rem 0 0; line-height: 1.4; }

    /* Code blocks */
    pre {
      background: #0d1117;
      border: 1px solid #333;
      border-radius: 6px;
      padding: 1rem;
      overflow-x: auto;
      margin: 0.75rem 0;
    }
    code { color: #c9d1d9; font-size: 0.9rem; }

    /* Nav */
    a { color: #7c8cf8; }
    .doc-nav {
      display: flex;
      justify-content: space-between;
      margin-top: 3rem;
      padding-top: 1rem;
      border-top: 1px solid #333;
    }
    .doc-nav a { color: #7c8cf8; text-decoration: none; }
  </style>
</Base>
