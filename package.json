{
  "name": "@astrolexisai/kcode",
  "version": "2.10.399",
  "description": "AI-powered coding assistant for the terminal - by Astrolexis",
  "author": "Astrolexis",
  "module": "src/index.ts",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AstrolexisAI/KCode.git"
  },
  "keywords": [
    "ai",
    "coding-assistant",
    "terminal",
    "llm",
    "ollama",
    "llama-cpp",
    "anthropic",
    "openai",
    "cli"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "bin": {
    "kcode": "./dist/kcode"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "build": "bun run build.ts",
    "build:dev": "bun run build.ts --dev",
    "build:web": "cd src/web && bunx vite build",
    "dev:web": "cd src/web && bunx vite",
    "typecheck": "bun run --bun tsc --noEmit",
    "lint": "biome check src/ --diagnostic-level=error",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:ci": "bun test --timeout=30000",
    "version:patch": "bun run --bun npm version patch",
    "version:minor": "bun run --bun npm version minor",
    "version:major": "bun run --bun npm version major"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.2",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "ora": "^9.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.8"
  }
}
