# dependencies (bun install)
node_modules

# output
out
dist
*.tgz
kcode

# reference source
reference-src/

# code coverage
coverage
*.lcov

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store

# KCode runtime data (never commit)
license.json
server.pid
server.port
server.log
awareness.db
awareness.db-wal
awareness.db-shm
pro-cache.json

# Integration-test database state (contains @test.com fixtures, not
# real customer data — but still shouldn't be committed because it
# grows on every test run and pollutes git history).
data/
!data/.gitkeep

# Audit reports are output artifacts, regenerated every `kcode audit`
# run. Not secrets, but not source-of-truth either.
AUDIT_REPORT.md
AUDIT_REPORT.json
AUDIT_REPORT.sarif
AUDIT.sarif

# Release binaries (use GitHub Releases instead)
release/
backend/data/

# Claude Code transient state (per-session, not source-of-truth)
.claude/scheduled_tasks.lock

# Benchmark run outputs (one per `bun run bench:audit`).
# Baselines (baseline-v*.json) ARE tracked — they're the regression
# floor. Timestamped runs are ephemeral.
benchmarks/audit/results/run-*.json

# Local-only working files (kept on disk, never committed).
kulsh/
docs/brochure.pdf
__pycache__/
